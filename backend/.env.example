# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=E-commerce API
APP_VERSION=1.0.0
APP_ENV=development

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=uma-chave-secreta-longa-e-aleatoria
JWT_ISSUER=go-ecommerce-api
JWT_AUDIENCE=go-ecommerce-api
JWT_ACCESS_TOKEN_TTL_MINUTES=15

# -----------------------------------------------------------------------------
# Auth cookie
# -----------------------------------------------------------------------------
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
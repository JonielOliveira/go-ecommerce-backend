# -----------------------------------------------------------------------------
# Go / Dev Container
# -----------------------------------------------------------------------------

# Variante da imagem base do Dev Container para Go.
# Exemplo: 1.25-bookworm, 1.26-bookworm, 1.26-trixie
GO_VARIANT=1.26-bookworm

# Instala o cliente do PostgreSQL dentro do container da aplicação.
# Útil para usar comandos como: psql
INSTALL_POSTGRES_CLIENT=true

# Instala o Air, ferramenta de hot reload para Go.
# Útil para reiniciar a aplicação automaticamente durante o desenvolvimento.
INSTALL_AIR=true

# Instala a ferramenta golang-migrate.
# Útil para controlar migrations do banco de dados.
INSTALL_MIGRATE=true

# Instala o sqlc.
# Útil para gerar código Go a partir de queries SQL.
INSTALL_SQLC=true


# -----------------------------------------------------------------------------
# Docker Compose
# -----------------------------------------------------------------------------

# Nome do projeto Docker Compose.
# Esse nome é usado como prefixo para recursos criados pelo Compose,
# como redes, volumes e containers, quando container_name não é definido.
COMPOSE_PROJECT_NAME=backend-dev

# Driver da rede Docker usada pelos containers.
# Para desenvolvimento local, normalmente use bridge.
APP_NETWORK_DRIVER=bridge


# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------

# Nome do container da aplicação.
# Atenção: container_name precisa ser único na sua máquina.
APP_CONTAINER_NAME=app-dev

# Porta exposta na sua máquina.
# Exemplo: localhost:8080
APP_EXTERNAL_PORT=8080

# Porta interna usada pela aplicação dentro do container.
APP_INTERNAL_PORT=8080

# Pasta principal do projeto dentro do container.
# Esse caminho deve bater com o working_dir e com o volume no docker-compose.yml.
WORKSPACE_FOLDER=/workspaces/app


# -----------------------------------------------------------------------------
# PostgreSQL - Container
# -----------------------------------------------------------------------------

# Nome do container do PostgreSQL.
# Atenção: container_name precisa ser único na sua máquina.
POSTGRES_CONTAINER_NAME=postgres-db

# Tag da imagem oficial do PostgreSQL.
# Exemplos: 18, 18.4, 18-alpine
POSTGRES_TAG=18

# Porta exposta na sua máquina para acessar o PostgreSQL.
# Exemplo: localhost:5432
POSTGRES_EXTERNAL_PORT=5432

# Porta interna do PostgreSQL dentro do container.
# Normalmente é 5432.
POSTGRES_INTERNAL_PORT=5432

# Diretório de dados do PostgreSQL dentro do container.
# Para PostgreSQL 18+, recomenda-se /var/lib/postgresql.
# Para PostgreSQL 17 ou anterior, pode ser necessário usar /var/lib/postgresql/data.
POSTGRES_DATA_DIR=/var/lib/postgresql


# -----------------------------------------------------------------------------
# PostgreSQL - Credenciais e conexão
# -----------------------------------------------------------------------------

# Nome do banco de dados criado automaticamente na primeira inicialização.
POSTGRES_DB=postgres

# Usuário do PostgreSQL criado automaticamente na primeira inicialização.
POSTGRES_USER=postgres

# Senha do usuário do PostgreSQL.
# Em ambiente real, não use senhas simples e não versionar o arquivo .env real.
POSTGRES_PASSWORD=postgres

# Hostname usado pela aplicação para acessar o banco dentro da rede Docker.
# Deve ser o nome do serviço do PostgreSQL no docker-compose.yml.
# Exemplo: service db -> hostname db
POSTGRES_HOSTNAME=db


# -----------------------------------------------------------------------------
# PostgreSQL - Healthcheck
# -----------------------------------------------------------------------------

# Intervalo entre as verificações de saúde do banco.
POSTGRES_HEALTH_INTERVAL=10s

# Tempo máximo de espera para cada verificação.
POSTGRES_HEALTH_TIMEOUT=5s

# Número de tentativas antes de considerar o container como unhealthy.
POSTGRES_HEALTH_RETRIES=5

# Tempo inicial de tolerância antes do healthcheck começar a contar falhas.
POSTGRES_HEALTH_START_PERIOD=30s
